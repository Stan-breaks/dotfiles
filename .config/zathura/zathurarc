# UI Settings
set selection-clipboard clipboard
set font "JetBrains Mono 11"

# Background and foreground
set default-bg "#1d2021"
set default-fg "#ebdbb2"

# Recoloring (dark mode)
set recolor true
set recolor-lightcolor "#1d2021"
set recolor-darkcolor "#ebdbb2"
set recolor-reverse-video true
set recolor-keephue true

# Status bar
set statusbar-fg "#ebdbb2"
set statusbar-bg "#3c3836"
set statusbar-h-padding 10
set statusbar-v-padding 5

# Input bar
set inputbar-bg "#3c3836"
set inputbar-fg "#ebdbb2"

# Notification colors
set notification-error-bg "#cc241d"
set notification-error-fg "#ebdbb2"
set notification-warning-bg "#d79921"
set notification-warning-fg "#1d2021"
set notification-bg "#98971a"
set notification-fg "#1d2021"

# Completion menu
set completion-bg "#3c3836"
set completion-fg "#ebdbb2"
set completion-group-bg "#504945"
set completion-group-fg "#83a598"
set completion-highlight-bg "#665c54"
set completion-highlight-fg "#fbf1c7"

# Index mode
set index-bg "#1d2021"
set index-fg "#ebdbb2"
set index-active-bg "#504945"
set index-active-fg "#fbf1c7"

# Highlight colors
set highlight-color "#d79921"
set highlight-active-color "#fabd2f"

# Rendering options
set smooth-scroll true
set scroll-step 50
set scroll-hstep 50
set scroll-wrap false
set advance-pages-per-row false
set continuous-hist-save true

# Zoom and fit
set zoom-min 10
set zoom-max 1000
set zoom-step 10
set fit-width true
set adjust-open "best-fit"

# Page settings
set page-padding 5
set pages-per-row 1
set first-page-column 1

# Window settings
set window-title-basename true
set statusbar-basename true
set statusbar-home-tilde true

# Key bindings (Gruvbox-friendly)
map r recolor
map p print
map i zoom in
map o zoom out
map R rotate
map K zoom in
map J zoom out
map h scroll left
map j scroll down
map k scroll up
map l scroll right
map <C-d> scroll half-down
map <C-u> scroll half-up
map <C-f> scroll full-down
map <C-b> scroll full-up
map gg goto top
map G goto bottom
map <Space> scroll full-down
map <S-Space> scroll full-up
map <BackSpace> scroll full-up
map n search forward
map N search backward
map <Escape> abort
map q quit
map <C-q> quit

# Toggle settings
map <F1> toggle_statusbar
map <F2> toggle_inputbar
map <F3> focus_inputbar ":set pages-per-row "
map <F4> focus_inputbar ":set first-page-column "
map <F5> focus_inputbar ":set zoom "

# Additional helpful bindings
map = zoom 100
map + zoom in
map - zoom out
map <C-=> zoom in
map <C--> zoom out
map <C-0> zoom 100
